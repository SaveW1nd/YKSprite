FROM node:22-alpine
WORKDIR /app
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY scripts ./scripts
COPY apps/web ./apps/web
RUN corepack enable && pnpm install --filter @yksprite/web --frozen-lockfile
EXPOSE 5173
CMD ["pnpm", "--filter", "@yksprite/web", "dev", "--host", "0.0.0.0"]
