{
  "name": "yksprite",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "start:service": "node apps/service/dist/index.js",
    "watch:autoplay-debug": "node scripts/watch-autoplay-debug.mjs",
    "lint": "pnpm -r --if-present lint",
    "test": "vitest run",
    "build": "pnpm -r --if-present build",
    "package:desktop": "pnpm --filter @yksprite/desktop --fail-if-no-match package",
    "docker:build": "docker build -f docker/Dockerfile -t yksprite:dev .",
    "docker:run": "docker run --rm -p 3000:3000 -v \"$PWD/data:/app/data\" yksprite:dev",
    "docker:smoke": "docker run --rm -p 3000:3000 -v \"$PWD/data:/app/data\" yksprite:dev",
    "postinstall": "node scripts/ensure-better-sqlite3.cjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@yksprite/core": "workspace:*",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
